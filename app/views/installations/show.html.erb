<turbo-frame id="modal">
  <%= render "shared/modal", title: @installation.repo, size: "large" do %>
    <div class="space-y-5">

      <div>
        <div class="text-xs font-semibold theme-text-secondary uppercase tracking-wide mb-2">Webhook URL</div>
        <div class="flex items-center space-x-2" data-controller="copy">
          <input type="text" readonly value="<%= webhooks_github_url %>"
                 data-copy-target="source"
                 class="input-field text-sm font-mono flex-1 bg-gray-50"/>
          <button data-action="copy#copy"
                  class="btn-secondary text-sm flex-shrink-0">Copy</button>
          <span data-copy-target="feedback" class="text-xs text-green-600 w-8 flex-shrink-0"></span>
        </div>
        <p class="text-xs theme-text-secondary mt-1.5">
          Add as <code class="bg-gray-100 px-1 py-0.5 rounded text-gray-700 font-mono">WEBHOOK_URL</code>
          in <strong>Settings -> Secrets and variables -> Actions</strong>.
        </p>
      </div>

      <div>
        <div class="text-xs font-semibold theme-text-secondary uppercase tracking-wide mb-2">Webhook Secret</div>
        <div class="flex items-center space-x-2" data-controller="copy">
          <input type="password" readonly value="<%= @installation.webhook_secret %>"
                 data-copy-target="source"
                 class="input-field text-sm font-mono flex-1 bg-gray-50"/>
          <button data-action="copy#copy"
                  class="btn-secondary text-sm flex-shrink-0">Copy</button>
          <span data-copy-target="feedback" class="text-xs text-green-600 w-8 flex-shrink-0"></span>
        </div>
        <p class="text-xs theme-text-secondary mt-1.5">
          Add as <code class="bg-gray-100 px-1 py-0.5 rounded text-gray-700 font-mono">WEBHOOK_SECRET</code>
          in the same location.
        </p>
      </div>

      <div class="grid grid-cols-2 gap-4 pt-1 border-t theme-border">
        <div>
          <div class="text-xs font-semibold theme-text-secondary uppercase tracking-wide mb-1">Owner</div>
          <div class="text-sm font-mono theme-text-primary"><%= @installation.owner %></div>
        </div>
        <div>
          <div class="text-xs font-semibold theme-text-secondary uppercase tracking-wide mb-1">Added</div>
          <div class="text-sm theme-text-primary"><%= @installation.created_at.strftime("%b %-d, %Y") %></div>
        </div>
      </div>

      <div class="pt-1 border-t theme-border flex items-center justify-between">
        <p class="text-xs theme-text-secondary">Removing this repo will delete all associated PR data.</p>
        <%= button_to "Remove Repo", installation_path(@installation),
              method: :delete,
              data: { turbo_confirm: "Remove #{@installation.repo}? This cannot be undone." },
              class: "btn-danger text-sm" %>
      </div>
    </div>
  <% end %>
</turbo-frame>
