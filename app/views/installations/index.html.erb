<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold">Connected Repos</h1>
  <%= link_to "Add Repo", new_installation_path, class: "bg-gray-900 text-white text-sm px-4 py-2 rounded-lg hover:bg-gray-700 transition" %>
</div>

<% if @installations.empty? %>
  <div class="text-center py-16 text-gray-400">
    <p class="text-lg mb-2">No repos connected yet.</p>
    <p class="text-sm">Add a repo to get started.</p>
  </div>
<% else %>
  <div class="bg-white rounded-xl border border-gray-200 divide-y divide-gray-100">
    <% @installations.each do |installation| %>
      <div class="px-5 py-4 flex items-center justify-between">
        <div>
          <div class="font-medium"><%= installation.repo %></div>
          <div class="text-xs text-gray-400 mt-0.5">Added <%= time_ago_in_words(installation.created_at) %> ago</div>
        </div>
        <div class="flex items-center gap-3">
          <%= link_to "View", installation_path(installation), class: "text-sm text-gray-600 hover:text-gray-900" %>
          <%= button_to "Remove", installation_path(installation), method: :delete, data: { turbo_confirm: "Remove #{installation.repo}?" }, class: "text-sm text-red-500 hover:text-red-700 bg-transparent border-0 cursor-pointer" %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
