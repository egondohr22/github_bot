<div class="max-w-lg mx-auto">
  <h1 class="text-2xl font-bold mb-6">Add Repo</h1>

  <%= form_with model: @installation, class: "bg-white rounded-xl border border-gray-200 p-6 space-y-5" do |f| %>
    <% if @installation.errors.any? %>
      <div class="px-4 py-3 bg-red-50 border border-red-200 text-red-800 rounded-lg text-sm">
        <% @installation.errors.full_messages.each do |msg| %>
          <div><%= msg %></div>
        <% end %>
      </div>
    <% end %>

    <div>
      <%= f.label :repo, "Repository", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <% if @repos.any? %>
        <%= f.select :repo, @repos,
              { include_blank: "Select a repository…" },
              class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-400" %>
      <% else %>
        <%= f.text_field :repo, placeholder: "e.g. myorg/myrepo",
              class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-400" %>
        <p class="text-xs text-gray-400 mt-1">Could not load repos — enter manually.</p>
      <% end %>
    </div>

    <div class="flex gap-3 pt-2">
      <%= f.submit "Add Repo", class: "bg-gray-900 text-white px-5 py-2 rounded-lg text-sm font-medium hover:bg-gray-700 transition cursor-pointer" %>
      <%= link_to "Cancel", installations_path, class: "text-sm text-gray-500 hover:text-gray-700 py-2" %>
    </div>
  <% end %>
</div>
