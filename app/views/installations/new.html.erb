<turbo-frame id="modal">
  <%= render "shared/modal", title: "Add Repository" do %>
    <%= form_with model: @installation, data: { turbo_frame: "_top" } do |f| %>
      <% if @installation.errors.any? %>
        <div class="mb-4 px-4 py-3 bg-red-50 border border-red-200 text-red-700 rounded-lg text-sm">
          <% @installation.errors.full_messages.each do |msg| %>
            <div><%= msg %></div>
          <% end %>
        </div>
      <% end %>

      <div class="space-y-4">
        <div>
          <%= f.label :repo, "Repository", class: "block text-sm font-medium theme-text-primary mb-1.5" %>

          <% if @repos.any? %>
            <%# Custom searchable dropdown %>
            <div class="relative" data-controller="select">
              <input type="hidden" name="installation[repo]" data-select-target="input" value="">

              <button type="button"
                      data-action="click->select#toggle"
                      class="input-field text-sm flex items-center justify-between text-left">
                <span data-select-target="label" class="theme-text-secondary truncate">
                  Select a repository…
                </span>
                <svg data-select-target="chevron"
                     class="w-4 h-4 theme-text-secondary flex-shrink-0 ml-2 transition-transform duration-150"
                     fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>

              <div data-select-target="menu"
                   class="hidden absolute z-30 top-full left-0 right-0 mt-1 card shadow-xl
                          transform transition-all duration-150 origin-top overflow-hidden">
                <%# Search box %>
                <div class="p-2 border-b theme-border">
                  <div class="relative">
                    <svg class="absolute left-2.5 top-1/2 -translate-y-1/2 w-3.5 h-3.5 theme-text-secondary pointer-events-none"
                         fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0"/>
                    </svg>
                    <input type="text"
                           data-select-target="search"
                           data-action="input->select#filter"
                           placeholder="Search repositories…"
                           class="input-field text-sm pl-7 bg-white">
                  </div>
                </div>

                <%# Options list %>
                <div class="max-h-48 overflow-y-auto py-1">
                  <% @repos.each do |repo| %>
                    <button type="button"
                            data-select-target="option"
                            data-action="click->select#select"
                            data-select-value="<%= repo %>"
                            data-select-label="<%= repo %>"
                            class="w-full text-left px-3 py-2 text-sm theme-text-primary
                                   hover:theme-bg-secondary transition-colors font-mono">
                      <%= repo %>
                    </button>
                  <% end %>
                </div>
              </div>
            </div>

          <% else %>
            <%= f.text_field :repo, placeholder: "e.g. myorg/myrepo",
                  class: "input-field text-sm" %>
            <p class="text-xs theme-text-secondary mt-1">Could not load repos, enter manually.</p>
          <% end %>
        </div>

        <div class="flex items-center space-x-3 pt-1">
          <%= f.submit "Add Repository", class: "btn-primary text-sm" %>
          <%= link_to "Cancel", installations_path,
                class: "text-sm theme-text-secondary hover:theme-text-primary transition-colors" %>
        </div>
      </div>
    <% end %>
  <% end %>
</turbo-frame>
