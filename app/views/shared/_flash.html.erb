<% if notice.present? %>
  <div class="pointer-events-auto notification-toast translate-x-full opacity-0 transition-all duration-300 ease-out
              bg-white border border-green-200 rounded-xl shadow-lg"
       data-controller="notification"
       data-action="mouseenter->notification#pauseHide mouseleave->notification#resumeHide">
    <div class="p-4 pr-10">
      <div class="flex items-start space-x-3">
        <svg class="h-5 w-5 text-green-500 flex-shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
        </svg>
        <p class="text-sm text-gray-800"><%= notice %></p>
      </div>
    </div>
    <button data-action="click->notification#dismiss"
            class="absolute top-2 right-2 p-1.5 text-gray-400 hover:text-gray-600 transition-colors rounded-lg hover:bg-gray-100">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>
<% end %>

<% if alert.present? %>
  <div class="pointer-events-auto notification-toast translate-x-full opacity-0 transition-all duration-300 ease-out
              bg-white border border-red-200 rounded-xl shadow-lg"
       data-controller="notification"
       data-action="mouseenter->notification#pauseHide mouseleave->notification#resumeHide">
    <div class="p-4 pr-10">
      <div class="flex items-start space-x-3">
        <svg class="h-5 w-5 text-red-500 flex-shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
        </svg>
        <p class="text-sm text-gray-800"><%= alert %></p>
      </div>
    </div>
    <button data-action="click->notification#dismiss"
            class="absolute top-2 right-2 p-1.5 text-gray-400 hover:text-gray-600 transition-colors rounded-lg hover:bg-gray-100">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>
<% end %>
