<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold">Dashboard</h1>
  <%= link_to "Add Repo", new_installation_path, class: "bg-gray-900 text-white text-sm px-4 py-2 rounded-lg hover:bg-gray-700 transition" %>
</div>

<% if @pull_requests.empty? %>
  <div class="text-center py-16 text-gray-400">
    <p class="text-lg mb-2">No pull requests yet.</p>
    <p class="text-sm">Add a repo and set up the webhook to get started.</p>
  </div>
<% else %>
  <div class="bg-white rounded-xl border border-gray-200 divide-y divide-gray-100">
    <% @pull_requests.each do |pr| %>
      <div class="px-5 py-4 flex items-center justify-between">
        <div>
          <div class="flex items-center gap-2 mb-1">
            <span class="text-sm font-medium text-gray-500"><%= pr.installation.repo %></span>
            <span class="text-gray-300">#</span>
            <span class="font-semibold">#<%= pr.github_pr_number %></span>
          </div>
          <div class="text-xs text-gray-400">
            <% if pr.author.present? %>by <%= pr.author %> · <% end %>
            <%= pr.head_branch %> → <%= pr.base_branch %> ·
            <%= time_ago_in_words(pr.created_at) %> ago
          </div>
        </div>
        <div class="flex items-center gap-3">
          <%= render "shared/status_badge", status: pr.status %>
          <% latest_review = pr.reviews.last %>
          <% if latest_review %>
            <span class="text-xs text-gray-400"><%= latest_review.agent_results.count %> agent<%= latest_review.agent_results.count == 1 ? "" : "s" %></span>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
