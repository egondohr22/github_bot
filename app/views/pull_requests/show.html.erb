<div class="mb-6">
  <%= link_to "← Dashboard", dashboard_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
</div>

<div class="flex items-start justify-between mb-6">
  <div>
    <div class="text-sm text-gray-500 mb-1"><%= @pull_request.installation.repo %></div>
    <h1 class="text-2xl font-bold">PR #<%= @pull_request.github_pr_number %></h1>
    <div class="text-sm text-gray-400 mt-1">
      <%= @pull_request.head_branch %> → <%= @pull_request.base_branch %>
      <% if @pull_request.author.present? %> · by <%= @pull_request.author %><% end %>
    </div>
  </div>
  <%= render "shared/status_badge", status: @pull_request.status %>
</div>

<h2 class="text-lg font-semibold mb-3">Reviews</h2>

<% if @pull_request.reviews.empty? %>
  <div class="text-gray-400 text-sm py-8 text-center">No reviews yet.</div>
<% else %>
  <div class="bg-white rounded-xl border border-gray-200 divide-y divide-gray-100">
    <% @pull_request.reviews.order(created_at: :desc).each do |review| %>
      <%= link_to review_path(review), class: "px-5 py-4 flex items-center justify-between hover:bg-gray-50 transition block" do %>
        <div>
          <div class="text-sm font-medium mb-1">
            Review #<%= review.id %>
            <% if review.triggered_by_comment.present? %>
              <span class="text-gray-400 font-normal">· "<%= truncate(review.triggered_by_comment, length: 50) %>"</span>
            <% end %>
          </div>
          <div class="text-xs text-gray-400">
            <%= review.agent_results.size %> agent<%= review.agent_results.size == 1 ? "" : "s" %> ·
            <%= review.created_at.strftime("%b %-d, %Y at %H:%M") %>
          </div>
        </div>
        <%= render "shared/status_badge", status: review.status %>
      <% end %>
    <% end %>
  </div>
<% end %>
