<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="csrf-token" content="<%= form_authenticity_token %>">
    <title><%= content_for?(:page_title) ? "#{yield(:page_title)} · PR Review Bot" : "PR Review Bot" %></title>
    <%= stylesheet_link_tag "tailwind", "inter-font", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen theme-bg-secondary">
    <% if user_signed_in? %>
      <div class="h-screen flex theme-bg-secondary overflow-hidden">

        <div class="w-60 theme-bg-primary border-r theme-border flex flex-col flex-shrink-0">
          <div class="p-4 border-b theme-border flex-shrink-0">
            <%= link_to dashboard_path, class: "flex items-center space-x-2" do %>
              <div class="w-7 h-7 bg-blue-600 rounded-md flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <span class="text-sm font-semibold theme-text-primary">PR Review Bot</span>
            <% end %>
          </div>

          <nav class="flex-1 p-3 space-y-0.5 overflow-y-auto">
            <%= link_to dashboard_path,
                class: "nav-item #{'nav-item-active' if controller_name == 'dashboard'}" do %>
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
              </svg>
              <span>Dashboard</span>
            <% end %>

            <%= link_to installations_path,
                class: "nav-item #{'nav-item-active' if controller_name == 'installations'}" do %>
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/>
              </svg>
              <span>Repositories</span>
            <% end %>

            <%= link_to settings_path,
                class: "nav-item #{'nav-item-active' if controller_name == 'settings'}" do %>
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <span>Settings</span>
            <% end %>
          </nav>

          <div class="p-3 border-t theme-border flex-shrink-0">
            <div class="relative" data-controller="dropdown">
              <button data-action="click->dropdown#toggle"
                      class="flex items-center w-full px-3 py-2 text-left rounded-lg
                             theme-text-secondary hover:theme-text-primary hover:theme-bg-secondary
                             transition-all duration-200">
                <div class="w-7 h-7 rounded-full bg-blue-100 flex items-center justify-center mr-2.5 flex-shrink-0">
                  <span class="text-xs font-semibold text-blue-600">
                    <%= current_user.github_username.first.upcase %>
                  </span>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="text-sm font-medium theme-text-primary truncate">
                    <%= current_user.github_username %>
                  </div>
                  <div class="text-xs theme-text-secondary truncate"><%= current_user.email %></div>
                </div>
              </button>

              <div data-dropdown-target="menu"
                   class="hidden absolute bottom-full left-0 mb-1 w-full card shadow-xl z-10
                          transform transition-all duration-150 origin-bottom">
                <div class="p-1.5">
                  <%= link_to destroy_user_session_path,
                      data: { turbo_method: :delete },
                      class: "flex items-center space-x-2 px-3 py-2 text-sm theme-text-secondary
                              hover:theme-text-primary hover:theme-bg-secondary rounded-lg transition-colors w-full" do %>
                    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                    </svg>
                    <span>Sign out</span>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="flex-1 flex flex-col min-w-0">
          <header class="theme-bg-primary border-b theme-border px-6 py-4 flex-shrink-0">
            <div class="flex items-center justify-between">
              <h1 class="text-xl font-semibold theme-text-primary">
                <%= content_for?(:page_title) ? yield(:page_title) : controller_name.humanize %>
              </h1>
              <div class="flex items-center space-x-2.5">
                <div class="w-7 h-7 rounded-full bg-blue-100 flex items-center justify-center flex-shrink-0">
                  <span class="text-xs font-semibold text-blue-600">
                    <%= current_user.github_username.first.upcase %>
                  </span>
                </div>
                <span class="text-sm font-medium theme-text-secondary">
                  <%= current_user.github_username %>
                </span>
              </div>
            </div>
          </header>

          <main class="flex-1 overflow-y-auto theme-bg-secondary">
            <div class="p-6">
              <%= yield %>
            </div>
          </main>
        </div>
      </div>

    <% else %>
      <main class="min-h-screen theme-bg-secondary">
        <%= yield %>
      </main>
    <% end %>

    <div id="notifications" class="fixed top-4 right-4 z-50 space-y-2 pointer-events-none">
      <%= render "shared/flash" %>
    </div>

    <turbo-frame id="modal"></turbo-frame>
  </body>
</html>
