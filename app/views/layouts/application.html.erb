<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="csrf-token" content="<%= form_authenticity_token %>">
    <title><%= content_for?(:title) ? yield(:title) : "PR Review Bot" %></title>
    <%= stylesheet_link_tag "tailwind", "inter-font", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-gray-50 text-gray-900 min-h-screen">
    <nav class="bg-white border-b border-gray-200">
      <div class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between">
        <%= link_to "PR Review Bot", root_path, class: "font-semibold text-lg" %>
        <% if user_signed_in? %>
          <div class="flex items-center gap-6 text-sm">
            <%= link_to "Dashboard", dashboard_path, class: "text-gray-600 hover:text-gray-900" %>
            <%= link_to "Installations", installations_path, class: "text-gray-600 hover:text-gray-900" %>
            <%= link_to "Settings", settings_path, class: "text-gray-600 hover:text-gray-900" %>
            <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-gray-600 hover:text-gray-900" %>
          </div>
        <% end %>
      </div>
    </nav>

    <main class="max-w-5xl mx-auto px-4 py-8">
      <% if notice.present? %>
        <div class="mb-4 px-4 py-3 bg-green-50 border border-green-200 text-green-800 rounded-lg text-sm"><%= notice %></div>
      <% end %>
      <% if alert.present? %>
        <div class="mb-4 px-4 py-3 bg-red-50 border border-red-200 text-red-800 rounded-lg text-sm"><%= alert %></div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
